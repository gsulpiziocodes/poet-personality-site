# Admin dashboard credentials for /admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Optional extra hardening for admin session cookie signing
ADMIN_SESSION_SECRET=change-me-extra-secret

# Optional: send lead notifications via Resend
RESEND_API_KEY=re_xxx
LEADS_NOTIFY_EMAIL=you@example.com
# Optional sender (must be valid in your Resend account)
LEADS_FROM_EMAIL=onboarding@resend.dev

# Optional port override
PORT=8790
